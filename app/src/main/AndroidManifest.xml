<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.companyname.appname">

    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.CAPTURE_VIDEO_OUTPUT" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="28" />

    <!-- Force native lib extraction for FFmpeg -->
    <application
        android:name=".AudioCutterApp"
        android:allowBackup="true"
        android:icon="@drawable/ic_music_logo"
        android:label="قص الصوت"
        android:roundIcon="@drawable/ic_music_logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.AudioCutter">

        <activity
            android:name=".CutMethodActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".FileBrowserActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".AudioEditorActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".SilenceRemovalActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".NoiseReductionActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ErrorLogActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".AudioRecorderActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <service
            android:name=".MediaProjectionForegroundService"
            android:foregroundServiceType="mediaProjection|microphone"
            android:exported="false" />

    </application>

</manifest>
