<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/primary_dark"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="إزالة الضوضاء"
            android:textColor="@color/text_white"
            android:textStyle="bold"
            android:textSize="22sp"
            android:gravity="center"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tvNoiseFileName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_white"
            android:textSize="14sp"
            android:maxLines="2"
            android:ellipsize="middle"
            android:layout_marginBottom="24dp" />

        <SeekBar
            android:id="@+id/seekBarNoiseLevel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="3"
            android:progress="0"
            android:progressTint="@color/accent_color"
            android:thumbTint="@color/accent_color"
            android:layout_marginBottom="28dp" />

        <ProgressBar
            android:id="@+id/noiseProgressBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvNoiseStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#B8C1D9"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnNoiseApply"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="تطبيق"
            android:textSize="18sp"
            android:textColor="@color/text_white"
            android:backgroundTint="@color/accent_color"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

        <LinearLayout
            android:id="@+id/layoutNoiseResultButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="16dp">

            <Button
                android:id="@+id/btnNoisePlayPause"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="تشغيل النتيجة"
                android:textSize="16sp"
                android:textColor="@color/text_white"
                android:backgroundTint="#1565C0"
                android:textAllCaps="false"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnNoiseUndo"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="تراجع عن العملية"
                android:textSize="16sp"
                android:textColor="@color/text_white"
                android:backgroundTint="#B71C1C"
                android:textAllCaps="false"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnNoiseSave"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="@string/silence_save"
                android:textSize="16sp"
                android:textColor="@color/text_white"
                android:backgroundTint="#2E7D32"
                android:textAllCaps="false"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
