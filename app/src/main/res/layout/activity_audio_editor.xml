<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_dark"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

    <!-- سطح عرض الفيديو (مخفي) - ضروري لتشغيل MediaPlayer للفيديو -->
    <TextureView
        android:id="@+id/videoSurface"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="invisible" />

    <TextView
        android:id="@+id/tvMethodTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/method_label"
            android:textColor="@color/text_white"
            android:textSize="18sp"
            android:layout_marginBottom="8dp"/>

        <Spinner
            android:id="@+id/methodSpinner"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@android:drawable/btn_dropdown"
            android:layout_marginBottom="20dp"
            android:contentDescription="@string/method_label" />

        <!-- أزرار التشغيل (مشتركة لكل الطرق) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <ImageButton
                android:id="@+id/btnRewind"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/ic_rewind"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/rewind" />

            <ImageButton
                android:id="@+id/btnPlayPause"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginHorizontal="24dp"
                android:src="@drawable/ic_play"
                android:background="@drawable/ic_music_logo"
                android:padding="16dp"
                android:scaleType="fitCenter"
                android:contentDescription="@string/play_pause" />

            <ImageButton
                android:id="@+id/btnForward"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/ic_forward"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/forward" />
        </LinearLayout>

        <!-- وقت البداية والنهاية (مشتركة لكل الطرق) -->
        <TextView
            android:id="@+id/tvStartTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textColor="@color/accent_color"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvEndTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textColor="@color/accent_color"
            android:textSize="16sp"
            android:layout_gravity="end" />

        <!-- الطريقة 1: أشرطة التمرير -->
        <LinearLayout
            android:id="@+id/layoutSliders"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp">

            <SeekBar
                android:id="@+id/seekBarStart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="12dp"
                android:progressDrawable="@drawable/seekbar_track_start"
                android:thumb="@drawable/seekbar_thumb"
                android:thumbOffset="0dp"
                android:contentDescription="@string/start_slider" />

            <EditText
                android:id="@+id/etStartStepCustom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/start_step_hint"
                android:inputType="text"
                android:textColor="@color/text_white"
                android:textColorHint="#888888"
                android:layout_marginBottom="10dp" />

            <SeekBar
                android:id="@+id/seekBarEnd"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="12dp"
                android:progressDrawable="@drawable/seekbar_track_end"
                android:thumb="@drawable/seekbar_thumb"
                android:thumbOffset="0dp"
                android:contentDescription="@string/end_slider" />

            <EditText
                android:id="@+id/etEndStepCustom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/end_step_hint"
                android:inputType="text"
                android:textColor="@color/text_white"
                android:textColorHint="#888888"
                android:layout_marginBottom="4dp" />
        </LinearLayout>

        <!-- الطريقة 2: الإدخال اليدوي -->
        <LinearLayout
            android:id="@+id/layoutManual"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp"
            android:visibility="gone">

            <EditText
                android:id="@+id/etManualStart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/manual_start_hint"
                android:inputType="text"
                android:textColor="@color/text_white"
                android:textColorHint="#888888"
                android:layout_marginVertical="6dp" />

            <EditText
                android:id="@+id/etManualEnd"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/manual_end_hint"
                android:inputType="text"
                android:textColor="@color/text_white"
                android:textColorHint="#888888"
                android:layout_marginVertical="6dp" />

            <Button
                android:id="@+id/btnApplyManual"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/apply_manual"
                android:backgroundTint="@color/accent_color"
                android:textColor="@color/text_white"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <!-- الطريقة 3: التحديد الدقيق -->
        <LinearLayout
            android:id="@+id/layoutPrecise"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp"
            android:visibility="gone">

            <Button
                android:id="@+id/btnPreciseToggle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/precise_start"
                android:backgroundTint="@color/accent_color"
                android:textColor="@color/text_white"
                android:layout_marginVertical="6dp" />

            <Button
                android:id="@+id/btnPreciseListen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/precise_play_selection"
                android:backgroundTint="#3F51B5"
                android:textColor="@color/text_white"
                android:layout_marginVertical="6dp" />
        </LinearLayout>

        <!-- أزرار الحفظ والحذف (مشتركة) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp">

            <Button
                android:id="@+id/btnDeleteSegment"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/btn_delete_segment"
                android:backgroundTint="#B00020"
                android:textColor="@color/text_white" />

            <Button
                android:id="@+id/btnSaveSegment"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/btn_save_segment"
                android:backgroundTint="@color/accent_color"
                android:textColor="@color/text_white" />
        </LinearLayout>

        <!-- زر التراجع (أسفل أزرار الحذف والحفظ) -->
        <Button
            android:id="@+id/btnUndo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/btn_undo"
            android:backgroundTint="#FF9800"
            android:textColor="@color/text_white" />

        
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btnFinalSave"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="40dp"
            android:text="@string/btn_final_save"
            android:backgroundTint="@color/accent_color"
            android:textSize="18sp" />

    </LinearLayout>
</ScrollView>
